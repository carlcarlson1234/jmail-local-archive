# Database
DATABASE_URL=postgresql://jmail:jmail_local@localhost:5432/jmail

# Application
APP_PORT=3001

# Data paths (relative to project root)
RAW_DATA_ROOT=./data/raw/jmail
RAW_ASSETS_ROOT=./data/raw-assets
LOGS_ROOT=./data/logs

# Jmail data source
JMAIL_DATA_BASE_URL=https://data.jmail.world/v1
JMAIL_SITE_URL=https://jmail.world

# Asset download settings
ASSET_RATE_LIMIT_MS=1000
ASSET_MAX_RETRIES=3
